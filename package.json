{
  "name": "mineradio",
  "productName": "Mineradio优化版",
  "version": "2.1.2",
  "description": "沉浸式音乐播放器，融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "author": "Daine",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check:minimal": "node scripts/check-minimal-mode.js",
    "build:win": "electron-builder --win nsis",
    "build:win:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio优化版",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "Mineradio优化版",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio优化版",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "mineradio-setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Daine0717",
        "repo": "Mineradio-Daine-Optimized"
      }
    ]
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "Daine0717",
      "repo": "Mineradio-Daine-Optimized",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}
